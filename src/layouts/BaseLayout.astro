---
import MainHead from "../components/MainHead.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import AiChat from "../components/AiChat.astro";
import {
  ENABLE_PASSWORD_PROTECTION,
  PASSWORD_SESSION_KEY,
  SITE_PASSWORD,
} from "../config/security";

import "../styles/global.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<html lang="sv" transition:animate="none">
  <head>
    <MainHead title={title} description={description} />
  </head>
  <body
    class="flex min-h-svh flex-col bg-gray-800 bg-linear-to-tr from-violet-500 to-orange-300 bg-fixed"
    data-password-protection-enabled={ENABLE_PASSWORD_PROTECTION ? "true" : "false"}
    data-password={ENABLE_PASSWORD_PROTECTION ? SITE_PASSWORD : ""}
    data-password-session-key={PASSWORD_SESSION_KEY}
  >
    {
      ENABLE_PASSWORD_PROTECTION && (
        <div id="password-gate" class="stack-gate-overlay" aria-modal="true" role="dialog">
          <form id="password-gate-form" class="fade-in-up glass stack-gate-card">
            <h2 class="text-2xl font-bold text-white">Lösenord krävs</h2>
            <p class="mt-2 text-sm text-white/70 md:text-base">Ange lösenord för att fortsätta.</p>

            <div class="mt-5 flex w-full flex-col gap-3 sm:flex-row">
              <input
                id="password-gate-input"
                name="password"
                type="password"
                placeholder="Lösenord"
                class="stack-password-input"
                autocomplete="current-password"
                required
              />
              <button class="stack-unlock-btn" type="submit">Öppna</button>
            </div>

            <p id="password-gate-error" class="mt-3 hidden text-sm text-rose-300" aria-live="polite"></p>
          </form>
        </div>
      )
    }

    <header class="sticky top-0 z-50 flex-none">
      <Nav
        pages={[
          { name: "Om mig", url: "about" },
          { name: "CV", url: "cv" },
          { name: "Stack", url: "stack" },
        ]}
      />
    </header>

    <main class="flex grow flex-col items-center">
      <slot />
    </main>

    <Footer />

    <AiChat />

    <div class="squares" aria-hidden="true">
      <div class="glass"></div>
      <div class="glass"></div>
      <div class="glass"></div>
      <div class="glass hidden! md:block"></div>
      <div class="glass"></div>
      <div class="glass"></div>
      <div class="glass"></div>
      <div class="glass hidden! md:block"></div>
      <div class="glass"></div>
      <div class="glass hidden! md:block"></div>
    </div>
  </body>
</html>

<script>
  // Password gate initialization
  const initPasswordGate = () => {
    const enabled = document.body.dataset.passwordProtectionEnabled === "true";
    if (!enabled) {
      return;
    }

    const gate = document.getElementById("password-gate");
    const form = document.getElementById("password-gate-form") as HTMLFormElement | null;
    const input = document.getElementById("password-gate-input") as HTMLInputElement | null;
    const error = document.getElementById("password-gate-error");

    if (!gate || !form || !input || !error) {
      return;
    }

    const expectedPassword = document.body.dataset.password ?? "";
    const storageKey = document.body.dataset.passwordSessionKey ?? "mig-site-password-ok";

    const gateState = window as Window & { __passwordReloadHandled?: boolean };

    if (!gateState.__passwordReloadHandled) {
      const navigationEntry = performance.getEntriesByType("navigation")[0] as
        | PerformanceNavigationTiming
        | undefined;
      const isReload = navigationEntry?.type === "reload"
        || (performance as Performance & { navigation?: { type?: number } }).navigation?.type === 1;

      if (isReload) {
        sessionStorage.removeItem(storageKey);
      }

      gateState.__passwordReloadHandled = true;
    }

    if (sessionStorage.getItem(storageKey) === "true") {
      gate.classList.add("hidden");
      return;
    }

    gate.classList.remove("hidden");
    input.focus();

    const onSubmit = (event: SubmitEvent) => {
      event.preventDefault();
      if (input.value === expectedPassword) {
        sessionStorage.setItem(storageKey, "true");
        gate.classList.add("hidden");
        error.textContent = "";
        error.classList.add("hidden");
        input.value = "";
        return;
      }

      error.textContent = "Fel lösenord, forsök igen.";
      error.classList.remove("hidden");
      form.classList.remove("shake");
      void form.offsetWidth;
      form.classList.add("shake");
      input.value = "";
      input.focus();
    };

    if (!form.dataset.bound) {
      form.addEventListener("submit", onSubmit);
      form.dataset.bound = "true";
    }
  };

  let prevObserver: IntersectionObserver | null = null;

  const initRevealAnimations = () => {
    prevObserver?.disconnect();
    prevObserver = null;

    const reveals = document.querySelectorAll<HTMLElement>(".reveal");
    const revealOnces = document.querySelectorAll<HTMLElement>(".reveal-once");
    if (!reveals.length && !revealOnces.length) {
      return;
    }

    if (
      window.matchMedia("(prefers-reduced-motion: reduce)").matches
    ) {
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.target.classList.contains("reveal-once")) {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          } else {
            entry.target.classList.toggle("visible", entry.isIntersecting);
          }
        });
      },
      { threshold: 0.05 },
    );

    reveals.forEach((el) => observer.observe(el));
    revealOnces.forEach((el) => observer.observe(el));

    prevObserver = observer;
  };

  document.addEventListener("astro:page-load", initRevealAnimations);
  document.addEventListener("DOMContentLoaded", initRevealAnimations);
  document.addEventListener("astro:page-load", initPasswordGate);
  document.addEventListener("DOMContentLoaded", initPasswordGate);

  if (document.readyState !== "loading") {
    queueMicrotask(initRevealAnimations);
    queueMicrotask(initPasswordGate);
  }

  // ── Cursor trail ────────────────────────────────────────────
  function initCursorTrail() {
    if (window.matchMedia("(pointer: coarse)").matches) return;
    if (document.getElementById("cursor-trail-wrap")) return;

    const wrap = document.createElement("div");
    wrap.id = "cursor-trail-wrap";
    wrap.style.cssText =
      "position:fixed;inset:0;pointer-events:none;z-index:9998;overflow:hidden;";
    document.body.appendChild(wrap);

    // ── Ring cursor ──────────────────────────────────────
    const ring = document.createElement("div");
    ring.style.cssText = [
      "position:absolute",
      "width:28px",
      "height:28px",
      "border-radius:50%",
      "border:1.5px solid rgba(255,210,80,0.7)",
      "box-shadow:0 0 8px 2px rgba(255,190,40,0.25),inset 0 0 6px rgba(255,210,80,0.15)",
      "transform:translate(-50%,-50%)",
      "will-change:transform",
      "transition:width 0.18s,height 0.18s,border-color 0.18s,box-shadow 0.18s",
      "pointer-events:none",
    ].join(";");
    wrap.appendChild(ring);

    // ── Comet tail ───────────────────────────────────────
    const N = 18;
    const tail = Array.from({ length: N }, (_, i) => {
      const t = (N - i) / N;
      const size = Math.max(2, Math.round(t * 6));
      const el = document.createElement("div");
      el.style.cssText = [
        "position:absolute",
        `width:${size}px`,
        `height:${size}px`,
        "border-radius:50%",
        `background:radial-gradient(circle,rgba(255,220,80,${(t * 0.55).toFixed(2)}) 0%,transparent 70%)`,
        "transform:translate(-50%,-50%)",
        "will-change:transform",
        "pointer-events:none",
      ].join(";");
      wrap.appendChild(el);
      return { el, x: -200, y: -200 };
    });

    // ── Sparkle pool ─────────────────────────────────────
    const SPARK_COUNT = 8;
    type Spark = {
      el: HTMLDivElement;
      x: number;
      y: number;
      vx: number;
      vy: number;
      life: number;
      maxLife: number;
      active: boolean;
    };
    const sparks: Spark[] = Array.from({ length: SPARK_COUNT }, () => {
      const el = document.createElement("div");
      el.style.cssText = [
        "position:absolute",
        "width:3px",
        "height:3px",
        "border-radius:50%",
        "background:rgba(255,230,120,0.9)",
        "box-shadow:0 0 4px 1px rgba(255,210,60,0.6)",
        "transform:translate(-50%,-50%)",
        "will-change:transform,opacity",
        "pointer-events:none",
        "opacity:0",
      ].join(";");
      wrap.appendChild(el);
      return { el, x: 0, y: 0, vx: 0, vy: 0, life: 0, maxLife: 1, active: false };
    });

    let mx = -200, my = -200, raf = 0;
    let sparkTimer = 0;

    document.addEventListener("mousemove", (e) => {
      mx = e.clientX;
      my = e.clientY;
    });

    // Expand ring on click
    document.addEventListener("mousedown", () => {
      ring.style.width = "38px";
      ring.style.height = "38px";
      ring.style.borderColor = "rgba(255,180,40,0.9)";
      ring.style.boxShadow = "0 0 14px 4px rgba(255,190,40,0.45),inset 0 0 8px rgba(255,210,80,0.25)";
    });
    document.addEventListener("mouseup", () => {
      ring.style.width = "28px";
      ring.style.height = "28px";
      ring.style.borderColor = "rgba(255,210,80,0.7)";
      ring.style.boxShadow = "0 0 8px 2px rgba(255,190,40,0.25),inset 0 0 6px rgba(255,210,80,0.15)";
    });

    function emitSpark(x: number, y: number) {
      const s = sparks.find((sp) => !sp.active);
      if (!s) return;
      const angle = Math.random() * Math.PI * 2;
      const speed = Math.random() * 1.4 + 0.4;
      s.x = x; s.y = y;
      s.vx = Math.cos(angle) * speed;
      s.vy = Math.sin(angle) * speed;
      s.maxLife = Math.random() * 22 + 14;
      s.life = s.maxLife;
      s.active = true;
    }

    function tick() {
      // Ring follows cursor directly (smooth via CSS transition)
      ring.style.left = mx + "px";
      ring.style.top = my + "px";

      // Tail
      tail[0].x = mx;
      tail[0].y = my;
      for (let i = 1; i < N; i++) {
        tail[i].x += (tail[i - 1].x - tail[i].x) * 0.3;
        tail[i].y += (tail[i - 1].y - tail[i].y) * 0.3;
      }
      tail.forEach((d) => {
        d.el.style.left = d.x + "px";
        d.el.style.top = d.y + "px";
      });

      // Sparkle emit
      if (++sparkTimer % 4 === 0 && mx > -100) {
        emitSpark(
          tail[6].x + (Math.random() - 0.5) * 6,
          tail[6].y + (Math.random() - 0.5) * 6,
        );
      }

      // Sparkle update
      sparks.forEach((s) => {
        if (!s.active) return;
        s.x += s.vx;
        s.y += s.vy;
        s.vy += 0.04; // gravity
        s.vx *= 0.97;
        s.life--;
        const alpha = s.life / s.maxLife;
        s.el.style.opacity = alpha.toFixed(2);
        s.el.style.left = s.x + "px";
        s.el.style.top = s.y + "px";
        if (s.life <= 0) {
          s.active = false;
          s.el.style.opacity = "0";
        }
      });

      raf = requestAnimationFrame(tick);
    }
    raf = requestAnimationFrame(tick);

    document.addEventListener("astro:before-swap", () =>
      cancelAnimationFrame(raf),
    );
  }

  initCursorTrail();
  document.addEventListener("astro:page-load", initCursorTrail);
</script>

<style>
  @reference '../styles/global.css';

  .squares {
    @apply fixed bottom-0 left-0 -z-1000 h-svh w-full overflow-hidden;
    contain: strict;
  }

  .squares > div {
    @apply absolute -bottom-37.5 block h-5 w-5 rounded-[10%];
    animation: squares infinite linear;
  }

  .squares .glass {
    @apply overflow-visible border border-white/35 bg-white/15 backdrop-blur-none;
  }

  .squares .glass::after {
    @apply hidden;
  }

  .squares > div:nth-child(1) {
    left: 25%;
    width: 80px;
    height: 80px;
    animation-delay: 0s;
    animation-duration: 25s;
  }

  .squares > div:nth-child(2) {
    left: 10%;
    width: 20px;
    height: 20px;
    animation-delay: 2s;
    animation-duration: 12s;
  }

  .squares > div:nth-child(3) {
    left: 70%;
    width: 20px;
    height: 20px;
    animation-delay: 4s;
    animation-duration: 25s;
  }

  .squares > div:nth-child(4) {
    left: 40%;
    width: 60px;
    height: 60px;
    animation-delay: 0s;
    animation-duration: 18s;
  }

  .squares > div:nth-child(5) {
    left: 65%;
    width: 20px;
    height: 20px;
    animation-delay: 0s;
    animation-duration: 25s;
  }

  .squares > div:nth-child(6) {
    left: 75%;
    width: 110px;
    height: 110px;
    animation-delay: 3s;
    animation-duration: 25s;
  }

  .squares > div:nth-child(7) {
    left: 35%;
    width: 150px;
    height: 150px;
    animation-delay: 7s;
    animation-duration: 25s;
  }

  .squares > div:nth-child(8) {
    left: 50%;
    width: 25px;
    height: 25px;
    animation-delay: 15s;
    animation-duration: 45s;
  }

  .squares > div:nth-child(9) {
    left: 20%;
    width: 15px;
    height: 15px;
    animation-delay: 2s;
    animation-duration: 35s;
  }

  .squares > div:nth-child(10) {
    left: 85%;
    width: 150px;
    height: 150px;
    animation-delay: 0s;
    animation-duration: 11s;
  }

  .stack-gate-overlay {
    @apply fixed inset-0 z-9999 flex items-center justify-center bg-black/55 px-4 backdrop-blur-sm;
  }

  .stack-gate-overlay.hidden {
    @apply hidden;
  }

  .stack-gate-card {
    @apply w-full max-w-xl rounded-2xl p-8 text-center;
  }

  .stack-password-input {
    @apply w-full rounded-xl border border-white/20 bg-white/5 px-4 py-3 text-sm text-white outline-none transition-colors focus:border-white/40;
  }

  .stack-unlock-btn {
    @apply rounded-xl bg-white/15 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-white/25;
  }

  .stack-gate-card.shake {
    animation: stack-shake 360ms ease;
  }

  @keyframes stack-shake {
    0% {
      transform: translateX(0);
    }
    20% {
      transform: translateX(-8px);
    }
    40% {
      transform: translateX(8px);
    }
    60% {
      transform: translateX(-6px);
    }
    80% {
      transform: translateX(6px);
    }
    100% {
      transform: translateX(0);
    }
  }

  @keyframes squares {
    from {
      transform: translateY(0) rotate(0deg);
      opacity: 1;
      border-radius: 10%;
    }
    to {
      transform: translateY(-100svh) rotate(720deg);
      opacity: 0.25;
      border-radius: 50%;
    }
  }
</style>
