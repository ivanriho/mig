---
import MainHead from "../components/MainHead.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import AiChat from "../components/AiChat.astro";
import {
  defaultLang,
  getLocalePath,
  getNavPages,
  getSiteCopy,
  languageOptions,
  normalizeLang,
  type RouteKey,
  type SiteLang,
} from "../i18n";

import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  lang?: SiteLang;
  pageKey: RouteKey;
}

const {
  title,
  description,
  lang: rawLang = defaultLang,
  pageKey,
} = Astro.props;
const lang = normalizeLang(rawLang);
const copy = getSiteCopy(lang);
const basePath = import.meta.env.BASE_URL;
const mobileBlockContentByLang: Record<
  SiteLang,
  { title: string; text: string; continueText: string; continueButton: string }
> = {
  sv: {
    title: "Endast dator",
    text: "För den fullständiga upplevelsen, besök <strong>bit.ly/ivan-riho</strong> på din dator.",
    continueText: "Sidan är ännu inte helt anpassad för mobiler, men du är välkommen att kika runt ändå!",
    continueButton: "Öppna ändå",
  },
  en: {
    title: "Desktop Only",
    text: "For the full experience, visit <strong>bit.ly/ivan-riho</strong> on your computer.",
    continueText: "The site isn't fully optimised for mobile yet, but you're welcome to look around anyway!",
    continueButton: "Open anyway",
  },
  fr: {
    title: "Bureau uniquement",
    text: "Pour une expérience complète, visitez <strong>bit.ly/ivan-riho</strong> sur votre ordinateur.",
    continueText: "Le site n'est pas encore entièrement adapté aux mobiles, mais vous êtes libre de jeter un œil quand même !",
    continueButton: "Ouvrir quand même",
  },
  es: {
    title: "Solo escritorio",
    text: "Para la experiencia completa, visita <strong>bit.ly/ivan-riho</strong> en tu ordenador.",
    continueText: "El sitio aún no está completamente adaptado para móviles, ¡pero eres bienvenido a echar un vistazo de todas formas!",
    continueButton: "Abrir de todas formas",
  },
  zh: {
    title: "仅支持桌面端",
    text: "请在电脑上访问 <strong>bit.ly/ivan-riho</strong> 以获得最佳体验。",
    continueText: "该网站尚未完全适配移动端，但您仍可以随意浏览！",
    continueButton: "还是打开",
  },
};
const mobileBlockContent = mobileBlockContentByLang[lang];
const mobileLanguageLinks = languageOptions.map((option) => ({
  ...option,
  href: getLocalePath(basePath, option.code, pageKey),
  active: option.code === lang,
}));
---

<html lang={lang} transition:animate="none">
  <head>
    <MainHead title={title} description={description} />
    <script is:inline>
      (function () {
        var t = localStorage.getItem("site-theme") || "mystic";
        document.documentElement.dataset.theme = t;
      })();
    </script>
  </head>
  <body class="flex min-h-svh flex-col">
    <div class="device-blocker" role="alert" aria-live="polite">
      <div class="device-blocker__card glass">
        <h1 class="device-blocker__title">{mobileBlockContent.title}</h1>
        <p class="device-blocker__text" set:html={mobileBlockContent.text} />
        <p class="device-blocker__continue-text">{mobileBlockContent.continueText}</p>
        <button type="button" class="device-blocker__continue-button">
          {mobileBlockContent.continueButton}
        </button>
        <p class="device-blocker__lang-label">{copy.nav.chooseLanguage}</p>
        <div class="device-blocker__lang-list" role="list">
          {
            mobileLanguageLinks.map(({ code, label, href, active }) => (
              <a
                class:list={["device-blocker__lang-link", active && "device-blocker__lang-link--active"]}
                href={href}
                hreflang={code}
                lang={code}
                aria-current={active ? "true" : undefined}
              >
                {label}
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <header class="sticky top-0 z-50 flex-none">
      <Nav pages={getNavPages(basePath, lang)} lang={lang} routeKey={pageKey} />
    </header>

    <main class="flex grow flex-col items-center">
      <slot />
    </main>

    <Footer lang={lang} text={copy.footer.text} />

    <AiChat lang={lang} />

    <div class="squares" aria-hidden="true">
      <div class="glass"></div>
      <div class="glass"></div>
      <div class="glass"></div>
      <div class="glass hidden! md:block"></div>
      <div class="glass"></div>
      <div class="glass"></div>
      <div class="glass"></div>
      <div class="glass hidden! md:block"></div>
      <div class="glass"></div>
      <div class="glass hidden! md:block"></div>
    </div>
  </body>
</html>

<style is:global>
  .device-blocker {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 99999;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background:
      radial-gradient(circle at 20% 10%, rgba(88, 28, 135, 0.25), transparent 42%),
      radial-gradient(circle at 80% 90%, rgba(55, 15, 100, 0.22), transparent 40%),
      linear-gradient(130deg, rgba(8, 4, 20, 0.97), rgba(15, 8, 35, 0.97));
    backdrop-filter: blur(10px);
  }

  .device-blocker__card {
    max-width: 36rem;
    width: min(100%, 36rem);
    border-radius: 1.6rem;
    padding: 1.3rem 1.2rem;
    color: rgba(255, 255, 255, 0.95);
    text-align: center;
  }

  .device-blocker__title {
    margin: 0;
    font-size: clamp(1.35rem, 4.6vw, 1.95rem);
    font-weight: 700;
  }

  .device-blocker__text {
    margin: 0.6rem 0 0;
    font-size: clamp(0.95rem, 3.6vw, 1.05rem);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.86);
  }

  .device-blocker__continue-text {
    margin: 0.8rem 0 0;
    color: rgba(255, 255, 255, 0.95);
    font-size: 0.93rem;
    line-height: 1.45;
  }

  .device-blocker__continue-button {
    margin-top: 0.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.36);
    background: rgba(255, 255, 255, 0.14);
    padding: 0.68rem 1rem;
    min-width: 10rem;
    font-weight: 700;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 1);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      0 10px 28px rgba(0, 0, 0, 0.16);
  }

  .device-blocker__lang-label {
    margin: 1rem 0 0;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.68);
  }

  .device-blocker__lang-list {
    margin-top: 0.7rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.55rem;
  }

  .device-blocker__lang-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 5.4rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.08);
    padding: 0.38rem 0.8rem;
    font-size: 0.86rem;
    color: rgba(255, 255, 255, 0.92);
    text-decoration: none;
  }

  .device-blocker__lang-link--active {
    border-color: rgba(255, 255, 255, 0.48);
    background: rgba(255, 255, 255, 0.2);
    font-weight: 700;
  }

  body.device-blocked {
    overflow: hidden;
  }

  body.device-blocked > * {
    display: none !important;
  }

  body.device-blocked > .device-blocker {
    display: flex !important;
  }
</style>

<script>
  let prevObserver: IntersectionObserver | null = null;
  let cleanupDesktopOnly: (() => void) | null = null;
  const mobileBypassStorageKey = "allow-mobile-view";

  const initDesktopOnlyGuard = () => {
    cleanupDesktopOnly?.();

    const query = window.matchMedia("(max-width: 900px), (pointer: coarse)");
    const apply = () => {
      const allowMobileView = window.sessionStorage.getItem(mobileBypassStorageKey) === "true";
      document.body.classList.toggle("device-blocked", query.matches && !allowMobileView);
    };

    apply();

    if (typeof query.addEventListener === "function") {
      query.addEventListener("change", apply);
      cleanupDesktopOnly = () => query.removeEventListener("change", apply);
      return;
    }

    query.addListener(apply);
    cleanupDesktopOnly = () => query.removeListener(apply);
  };

  const initMobileContinueButton = () => {
    const button = document.querySelector<HTMLButtonElement>(".device-blocker__continue-button");
    if (!button) {
      return;
    }

    button.onclick = () => {
      window.sessionStorage.setItem(mobileBypassStorageKey, "true");
      document.body.classList.remove("device-blocked");
    };
  };

  const initRevealAnimations = () => {
    prevObserver?.disconnect();
    prevObserver = null;

    const reveals = document.querySelectorAll<HTMLElement>(".reveal");
    const revealOnces = document.querySelectorAll<HTMLElement>(".reveal-once");
    if (!reveals.length && !revealOnces.length) {
      return;
    }

    if (
      window.matchMedia("(prefers-reduced-motion: reduce)").matches
    ) {
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.target.classList.contains("reveal-once")) {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          } else {
            entry.target.classList.toggle("visible", entry.isIntersecting);
          }
        });
      },
      { threshold: 0.05 },
    );

    reveals.forEach((el) => observer.observe(el));
    revealOnces.forEach((el) => observer.observe(el));

    prevObserver = observer;
  };

  // ── Persist theme across View Transitions ───────────────
  document.addEventListener("astro:before-swap", (e) => {
    const theme = localStorage.getItem("site-theme") || "mystic";
    (e as any).newDocument.documentElement.dataset.theme = theme;
  });

  document.addEventListener("astro:page-load", () => {
    initDesktopOnlyGuard();
    initMobileContinueButton();
    initRevealAnimations();
    initThemeToggle();
  });

  document.addEventListener("DOMContentLoaded", () => {
    initDesktopOnlyGuard();
    initMobileContinueButton();
    initRevealAnimations();
    initThemeToggle();
  });

  if (document.readyState !== "loading") {
    queueMicrotask(() => {
      initDesktopOnlyGuard();
      initMobileContinueButton();
      initRevealAnimations();
      initThemeToggle();
    });
  }

  // ── Cursor trail ────────────────────────────────────────────
  function initCursorTrail() {
    if (window.matchMedia("(pointer: coarse)").matches) return;
    if (document.getElementById("cursor-trail-wrap")) return;

    const _orig = document.documentElement.dataset.theme !== "mystic";
    const _mat  = document.documentElement.dataset.theme === "matrix";
    const _rc  = _mat ? "rgba(74,222,128,0.75)" : _orig ? "rgba(255,210,80,0.7)"  : "rgba(255,255,255,0.6)";
    const _rg  = _mat
      ? "0 0 8px 2px rgba(34,197,94,0.3),inset 0 0 6px rgba(74,222,128,0.15)"
      : _orig
      ? "0 0 8px 2px rgba(255,190,40,0.25),inset 0 0 6px rgba(255,210,80,0.15)"
      : "0 0 8px 2px rgba(255,255,255,0.12),inset 0 0 6px rgba(255,255,255,0.06)";
    const _rcc = _mat ? "rgba(74,222,128,0.92)"  : _orig ? "rgba(255,180,40,0.9)"  : "rgba(255,255,255,0.88)";
    const _rcg = _mat
      ? "0 0 16px 4px rgba(34,197,94,0.55),inset 0 0 8px rgba(74,222,128,0.25)"
      : _orig
      ? "0 0 14px 4px rgba(255,190,40,0.45),inset 0 0 8px rgba(255,210,80,0.25)"
      : "0 0 14px 4px rgba(255,255,255,0.3),inset 0 0 8px rgba(255,255,255,0.12)";
    const _sc  = _mat ? "rgba(74,222,128,0.9)"   : _orig ? "rgba(255,230,120,0.9)" : "rgba(255,255,255,0.8)";
    const _sg  = _mat ? "0 0 5px 2px rgba(34,197,94,0.6)" : _orig ? "0 0 4px 1px rgba(255,210,60,0.6)" : "0 0 5px 2px rgba(255,255,255,0.4)";
    const _tbg = (t: number) => _mat
      ? `rgba(34,197,94,${(t * 0.55).toFixed(2)})`
      : _orig
      ? `rgba(255,220,80,${(t * 0.55).toFixed(2)})`
      : `rgba(255,255,255,${(t * 0.4).toFixed(2)})`;

    const wrap = document.createElement("div");
    wrap.id = "cursor-trail-wrap";
    wrap.style.cssText =
      "position:fixed;inset:0;pointer-events:none;z-index:9998;overflow:hidden;";
    document.body.appendChild(wrap);

    // ── Ring cursor ──────────────────────────────────────
    const ring = document.createElement("div");
    ring.style.cssText = [
      "position:absolute",
      "width:28px",
      "height:28px",
      "border-radius:50%",
        `border:1.5px solid ${_rc}`,
        `box-shadow:${_rg}`,
      "transform:translate(-50%,-50%)",
      "will-change:transform",
      "transition:width 0.18s,height 0.18s,border-color 0.18s,box-shadow 0.18s",
      "pointer-events:none",
    ].join(";");
    wrap.appendChild(ring);

    // ── Comet tail ───────────────────────────────────────
    const N = 18;
    const tail = Array.from({ length: N }, (_, i) => {
      const t = (N - i) / N;
      const size = Math.max(2, Math.round(t * 6));
      const el = document.createElement("div");
      el.style.cssText = [
        "position:absolute",
        `width:${size}px`,
        `height:${size}px`,
        "border-radius:50%",
        `background:radial-gradient(circle,${_tbg(t)} 0%,transparent 70%)`,
        _orig ? "filter:none" : `filter:blur(${Math.round((1-t)*1.5)}px)`,
        "transform:translate(-50%,-50%)",
        "will-change:transform",
        "pointer-events:none",
      ].join(";");
      wrap.appendChild(el);
      return { el, x: -200, y: -200 };
    });

    // ── Sparkle pool ─────────────────────────────────────
    const SPARK_COUNT = 8;
    type Spark = {
      el: HTMLDivElement;
      x: number;
      y: number;
      vx: number;
      vy: number;
      life: number;
      maxLife: number;
      active: boolean;
    };
    const sparks: Spark[] = Array.from({ length: SPARK_COUNT }, () => {
      const el = document.createElement("div");
      el.style.cssText = [
        "position:absolute",
        "width:3px",
        "height:3px",
        "border-radius:50%",
        `background:${_sc}`,
        `box-shadow:${_sg}`,
        "transform:translate(-50%,-50%)",
        "will-change:transform,opacity",
        "pointer-events:none",
        "opacity:0",
      ].join(";");
      wrap.appendChild(el);
      return { el, x: 0, y: 0, vx: 0, vy: 0, life: 0, maxLife: 1, active: false };
    });

    let mx = -200, my = -200, raf = 0;
    let sparkTimer = 0;

    document.addEventListener("mousemove", (e) => {
      mx = e.clientX;
      my = e.clientY;
    });

    // Expand ring on click
    document.addEventListener("mousedown", () => {
      ring.style.width = "38px";
      ring.style.height = "38px";
      ring.style.borderColor = _rcc;
      ring.style.boxShadow = _rcg;
    });
    document.addEventListener("mouseup", () => {
      ring.style.width = "28px";
      ring.style.height = "28px";
      ring.style.borderColor = _rc;
      ring.style.boxShadow = _rg;
    });

    function emitSpark(x: number, y: number) {
      const s = sparks.find((sp) => !sp.active);
      if (!s) return;
      const angle = Math.random() * Math.PI * 2;
      const speed = Math.random() * 1.4 + 0.4;
      s.x = x; s.y = y;
      s.vx = Math.cos(angle) * speed;
      s.vy = Math.sin(angle) * speed;
      s.maxLife = Math.random() * 22 + 14;
      s.life = s.maxLife;
      s.active = true;
    }

    function tick() {
      // Ring follows cursor directly (smooth via CSS transition)
      ring.style.left = mx + "px";
      ring.style.top = my + "px";

      // Tail
      tail[0].x = mx;
      tail[0].y = my;
      for (let i = 1; i < N; i++) {
        tail[i].x += (tail[i - 1].x - tail[i].x) * 0.3;
        tail[i].y += (tail[i - 1].y - tail[i].y) * 0.3;
      }
      tail.forEach((d) => {
        d.el.style.left = d.x + "px";
        d.el.style.top = d.y + "px";
      });

      // Sparkle emit
      if (++sparkTimer % 4 === 0 && mx > -100) {
        emitSpark(
          tail[6].x + (Math.random() - 0.5) * 6,
          tail[6].y + (Math.random() - 0.5) * 6,
        );
      }

      // Sparkle update
      sparks.forEach((s) => {
        if (!s.active) return;
        s.x += s.vx;
        s.y += s.vy;
        s.vy += 0.04; // gravity
        s.vx *= 0.97;
        s.life--;
        const alpha = s.life / s.maxLife;
        s.el.style.opacity = alpha.toFixed(2);
        s.el.style.left = s.x + "px";
        s.el.style.top = s.y + "px";
        if (s.life <= 0) {
          s.active = false;
          s.el.style.opacity = "0";
        }
      });

      raf = requestAnimationFrame(tick);
    }
    raf = requestAnimationFrame(tick);

    document.addEventListener("astro:before-swap", () =>
      cancelAnimationFrame(raf),
    );
  }

  initCursorTrail();
  document.addEventListener("astro:page-load", initCursorTrail);

  // ── Theme toggle ────────────────────────────────────────────
  function initThemeToggle() {
    const btn = document.getElementById("theme-toggle") as HTMLButtonElement | null;
    if (!btn) return;

    const update = (theme: string) => {
      const labels: Record<string, string> = {
        mystic: "Switch to warm theme",
        original: "Switch to aurora theme",
        aurora: "Switch to matrix theme",
        matrix: "Switch to mystic theme",
      };
      btn.setAttribute("aria-label", labels[theme] ?? "Switch theme");
    };

    update(document.documentElement.dataset.theme || "mystic");

    btn.onclick = () => {
      const themes = ["mystic", "original", "aurora", "matrix"] as const;
      const current = document.documentElement.dataset.theme || "mystic";
      const idx = themes.indexOf(current as (typeof themes)[number]);
      const next = themes[(idx + 1) % themes.length];
      document.documentElement.dataset.theme = next;
      localStorage.setItem("site-theme", next);
      update(next);
      document.getElementById("cursor-trail-wrap")?.remove();
      initCursorTrail();
    };
  }
</script>

<style>
  @reference '../styles/global.css';

  .squares {
    @apply fixed bottom-0 left-0 -z-1000 h-svh w-full overflow-hidden;
    contain: strict;
  }

  .squares > div {
    @apply absolute -bottom-37.5 block h-5 w-5 rounded-[10%];
    animation: squares infinite linear;
  }

  .squares .glass {
    @apply overflow-visible border border-white/6 bg-white/2 backdrop-blur-none;
    box-shadow: none;
  }

  :global([data-theme="original"]) .squares .glass {
    border-color: rgba(255, 255, 255, 0.35);
    background-color: rgba(255, 255, 255, 0.15);
    box-shadow: none;
  }

  :global([data-theme="aurora"]) .squares .glass {
    border-color: rgba(255, 255, 255, 0.35);
    background-color: rgba(255, 255, 255, 0.15);
    box-shadow: none;
  }

  :global([data-theme="matrix"]) .squares .glass {
    border-color: rgba(34, 197, 94, 0.18);
    background-color: rgba(0, 20, 0, 0.4);
    box-shadow: 0 0 10px rgba(34, 197, 94, 0.06);
  }

  .squares .glass::after {
    @apply hidden;
  }

  .squares > div:nth-child(1) {
    left: 25%;
    width: 80px;
    height: 80px;
    animation-delay: 0s;
    animation-duration: 25s;
  }

  .squares > div:nth-child(2) {
    left: 10%;
    width: 20px;
    height: 20px;
    animation-delay: 2s;
    animation-duration: 12s;
  }

  .squares > div:nth-child(3) {
    left: 70%;
    width: 20px;
    height: 20px;
    animation-delay: 4s;
    animation-duration: 25s;
  }

  .squares > div:nth-child(4) {
    left: 40%;
    width: 60px;
    height: 60px;
    animation-delay: 0s;
    animation-duration: 18s;
  }

  .squares > div:nth-child(5) {
    left: 65%;
    width: 20px;
    height: 20px;
    animation-delay: 0s;
    animation-duration: 25s;
  }

  .squares > div:nth-child(6) {
    left: 75%;
    width: 110px;
    height: 110px;
    animation-delay: 3s;
    animation-duration: 25s;
  }

  .squares > div:nth-child(7) {
    left: 35%;
    width: 150px;
    height: 150px;
    animation-delay: 7s;
    animation-duration: 25s;
  }

  .squares > div:nth-child(8) {
    left: 50%;
    width: 25px;
    height: 25px;
    animation-delay: 15s;
    animation-duration: 45s;
  }

  .squares > div:nth-child(9) {
    left: 20%;
    width: 15px;
    height: 15px;
    animation-delay: 2s;
    animation-duration: 35s;
  }

  .squares > div:nth-child(10) {
    left: 85%;
    width: 150px;
    height: 150px;
    animation-delay: 0s;
    animation-duration: 11s;
  }

  @keyframes squares {
    from {
      transform: translateY(0) rotate(0deg);
      opacity: 1;
      border-radius: 10%;
    }
    to {
      transform: translateY(-100svh) rotate(720deg);
      opacity: 0.25;
      border-radius: 50%;
    }
  }
</style>
