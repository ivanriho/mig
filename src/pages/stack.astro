---
import BaseLayout from "../layouts/BaseLayout.astro";
import StackCard from "../components/StackCard.astro";

const randSkill = () => Math.floor(Math.random() * 16) + 85;
---

<BaseLayout
  title="Stack — Ivan Ristić Hofrén"
  description="Verktyg och tekniker jag kan just nu."
>
  <div
    id="stack-content"
    class="mt-8 mb-20 flex w-full max-w-5xl flex-col items-center gap-10 px-4 sm:mt-10 sm:px-6 sm:gap-14 lg:mt-20 lg:gap-18"
  >
    <div class="flex flex-col items-center gap-3 text-center">
      <h1 class="page-title drop-shadow-lg">Stack</h1>
      <p
        class="fade-in text-base text-white/60 [animation-delay:0.15s] md:text-lg"
      >
        Verktyg och tekniker jag arbetar med
      </p>
    </div>

    <div
      id="stack-filters"
      class="fade-in -mb-5 flex w-full items-baseline gap-3 [animation-delay:0.3s]"
    >
      <span class="filter-label shrink-0">Filtrera</span>
      <div
        id="filter-tags"
        class="flex min-w-0 flex-1 flex-wrap items-baseline gap-x-1"
      >
        <button class="filter-tag filter-active" data-tag="all">Alla</button>
        <span class="filter-dot">&middot;</span>
        <button class="filter-tag" data-tag="webbutveckling"
          >Webbutveckling</button
        >
        <span class="filter-dot">&middot;</span>
        <button class="filter-tag" data-tag="styling">Styling</button>
        <span class="filter-dot">&middot;</span>
        <button class="filter-tag" data-tag="backend">Backend</button>
        <span class="filter-dot">&middot;</span>
        <button class="filter-tag" data-tag="devops">DevOps</button>
      </div>
    </div>

    <div id="stack-grid" class="stagger-grid custom-grid">
      <StackCard
        name="html"
        label="HTML5"
        color="text-orange-200"
        description="Semantisk markup som bildar grunden för välstrukturerade, tillgängliga och SEO-vänliga webbsidor."
        category="Webbutveckling"
        href="https://developer.mozilla.org/en-US/docs/Web/HTML"
        linkLabel="MDN HTML"
        skill={randSkill()}
      />
      <StackCard
        name="tailwind"
        label="Tailwind CSS"
        color="text-sky-200"
        description="Utility-first CSS-ramverk som gör det lätt att bygga responsiva och konsekventa gränssnitt direkt i markupen."
        category="Styling"
        href="https://tailwindcss.com"
        linkLabel="TailwindCSS.com"
        skill={randSkill()}
      />
      <StackCard
        name="typescript"
        label="TypeScript"
        color="text-sky-200"
        description="Typsäker JavaScript som ger bättre autokomplettering, säkrare refaktorering och färre runtime-fel i större projekt."
        category="Webbutveckling"
        href="https://www.typescriptlang.org"
        linkLabel="TypeScriptLang.org"
        skill={randSkill()}
      />
      <StackCard
        name="nextjs"
        label="Next.js (Frontend + Backend)"
        color="text-slate-200"
        description="Mitt primära fullstack-ramverk för både frontend och backend med App Router, API routes, server actions och inbyggt stöd för TypeScript."
        category="Webbutveckling"
        href="https://nextjs.org"
        linkLabel="NextJS.org"
        skill={randSkill()}
      />
      <StackCard
        name="prisma"
        label="Prisma + PostgreSQL"
        color="text-violet-200"
        description="TypeScript-first ORM (Prisma) tillsammans med PostgreSQL för typsäkra modeller, migreringar och robust datalagring."
        category="Backend"
        links={[
          { href: "https://www.prisma.io", label: "Prisma.io" },
          { href: "https://www.postgresql.org", label: "PostgreSQL.org" },
        ]}
        skill={randSkill()}
      />
      <StackCard
        name="authjs"
        label="Auth.js"
        color="text-yellow-100"
        description="Flexibel autentiseringslösning med stöd för OAuth-leverantörer, e-postlänkar och credentials-inloggning."
        category="Backend"
        href="https://authjs.dev"
        linkLabel="AuthJS.dev"
        skill={randSkill()}
      />
      <StackCard
        name="git"
        label="Git"
        color="text-emerald-200"
        description="Distribuerat versionshanteringssystem jag använder dagligen för branchar, commits, merges och historik i kodbaser."
        category="DevOps"
        href="https://git-scm.com"
        linkLabel="Git-SCM.com"
        skill={randSkill()}
      />
      <StackCard
        name="github"
        label="GitHub"
        color="text-slate-200"
        description="Plattformen jag använder för versionshantering, pull requests, kodgranskning och deployment-flöden i projekt."
        category="DevOps"
        href="https://github.com"
        linkLabel="GitHub.com"
        skill={randSkill()}
      />
    </div>
  </div>

  <style>
    @reference '../styles/global.css';

    .filter-label {
      @apply text-[0.65rem] font-bold tracking-widest text-white/30 uppercase;
    }

    .filter-tag {
      @apply cursor-pointer border-none bg-transparent px-1 py-0.5 text-xs text-white/40 transition-colors duration-150 hover:text-white/70;
    }

    .filter-tag.filter-active {
      @apply text-white;
    }

    .filter-dot {
      @apply select-none text-xs text-white/20;
    }

  </style>

  <script>
    function initStackPage() {
      const stackContent = document.getElementById("stack-content");
      const filterBar = document.getElementById("stack-filters");
      const grid = document.getElementById("stack-grid");

      if (
        !stackContent ||
        !filterBar ||
        !grid
      ) {
        return;
      }

      const stackContentEl = stackContent;
      const filterBarEl = filterBar;
      const gridEl = grid;

      if (stackContentEl.dataset.initialized === "true") return;
      stackContentEl.dataset.initialized = "true";

      function animateSkillBars() {
        const fills =
          document.querySelectorAll<HTMLElement>(".skill-bar-fill");
        fills.forEach((fill, i) => {
          const skill = fill.dataset.skill;
          if (!skill) return;
          setTimeout(
            () => {
              fill.style.width = skill + "%";
            },
            300 + i * 70,
          );
        });
      }

      function startParticles() {
        let canvas = document.getElementById(
          "particle-canvas",
        ) as HTMLCanvasElement | null;
        if (canvas) return;
        canvas = document.createElement("canvas");
        canvas.id = "particle-canvas";
        canvas.style.cssText =
          "position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;";
        document.body.appendChild(canvas);

        const ctx = canvas.getContext("2d")!;
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;

        const particles = Array.from({ length: 70 }, () => ({
          x: Math.random() * canvas!.width,
          y: Math.random() * canvas!.height,
          r: Math.random() * 1.4 + 0.2,
          dx: (Math.random() - 0.5) * 0.25,
          dy: (Math.random() - 0.5) * 0.25,
          alpha: Math.random() * 0.35 + 0.05,
        }));

        window.addEventListener("resize", () => {
          if (!canvas) return;
          canvas.width = window.innerWidth;
          canvas.height = window.innerHeight;
        });

        function drawParticles() {
          if (!canvas || !ctx) return;
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          particles.forEach((p) => {
            p.x += p.dx;
            p.y += p.dy;
            if (p.x < 0) p.x = canvas!.width;
            if (p.x > canvas!.width) p.x = 0;
            if (p.y < 0) p.y = canvas!.height;
            if (p.y > canvas!.height) p.y = 0;
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(255,255,255,${p.alpha})`;
            ctx.fill();
          });
          requestAnimationFrame(drawParticles);
        }
        drawParticles();
      }

      startParticles();
      animateSkillBars();

      const allBtn = filterBarEl.querySelector<HTMLButtonElement>(
        '[data-tag="all"]',
      );
      const tagBtns = filterBarEl.querySelectorAll<HTMLButtonElement>(
        "[data-tag]:not([data-tag='all'])",
      );
      const cards = gridEl.querySelectorAll<HTMLElement>("[data-tags]");
      const activeTags = new Set<string>();

      function updateFilter() {
        cards.forEach((card) => {
          const cardTags = card.dataset.tags?.split(",") ?? [];
          const show =
            activeTags.size === 0 ||
            cardTags.some((t) => activeTags.has(t));
          if (show) {
            card.style.display = "";
          } else {
            card.style.display = "none";
            card.classList.remove("visible");
          }
        });
        allBtn?.classList.toggle("filter-active", activeTags.size === 0);
        tagBtns.forEach((btn) => {
          btn.classList.toggle(
            "filter-active",
            activeTags.has(btn.dataset.tag || ""),
          );
        });
      }

      allBtn?.addEventListener("click", () => {
        activeTags.clear();
        updateFilter();
      });

      tagBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          const tag = btn.dataset.tag;
          if (!tag) return;
          if (activeTags.has(tag)) {
            activeTags.delete(tag);
          } else {
            activeTags.add(tag);
          }
          updateFilter();
        });
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initStackPage, {
        once: true,
      });
    } else {
      initStackPage();
    }

    document.addEventListener("astro:page-load", initStackPage);
  </script>
</BaseLayout>
