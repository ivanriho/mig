---
import { Icon as AstroIcon } from "astro-icon/components";

import BaseLayout from "../layouts/BaseLayout.astro";

const cvFile = `${import.meta.env.BASE_URL}cv.pdf`;
---

<BaseLayout
  title="CV — Ivan Ristić Hofrén"
  description="Ladda ner CV för Ivan Ristić Hofrén"
>
  <div class="mt-16 mb-28 flex w-full max-w-4xl flex-col items-center gap-10 px-6 text-center lg:mt-20">
    <h1 class="page-title">CV</h1>

    <p class="fade-in max-w-2xl text-base text-white/80 [animation-delay:0.2s] md:text-lg">
      Här kan du ladda ner mitt CV direkt som PDF.
    </p>

    <div class="fade-in-up glass flex w-full max-w-xl flex-col items-center gap-6 rounded-2xl p-8 [animation-delay:0.3s]">
      <div class="inline-flex items-center gap-3 rounded-full border border-white/25 bg-white/8 px-4 py-2 text-white/90">
        <AstroIcon name="link" size="1.2em" />
        <span class="text-sm md:text-base">Ivan-Ristic-Hofren.pdf</span>
      </div>

      <a
        href={cvFile}
        download="Ivan-Ristic-Hofren.pdf"
        class="glass glass-cta inline-flex items-center gap-3 px-6 py-3 text-base font-semibold text-yellow-100 hover:text-white"
      >
        <AstroIcon name="link" size="1.2em" />
        Ladda ner CV
      </a>

      <a
        href={cvFile}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-white/70 underline decoration-white/40 underline-offset-4 hover:text-white"
      >
        <AstroIcon name="home" size="1em" />
        Öppna PDF i ny flik
      </a>
    </div>
  </div>
</BaseLayout>
