---
import { Icon as AstroIcon } from "astro-icon/components";

import BaseLayout from "../layouts/BaseLayout.astro";
import { defaultLang, getSiteCopy, normalizeLang, type SiteLang } from "../i18n";

interface Props {
  lang?: SiteLang;
}

const { lang: rawLang = defaultLang } = Astro.props;
const lang = normalizeLang(rawLang);
const copy = getSiteCopy(lang);

const cvFile = `${import.meta.env.BASE_URL}cv.pdf`;
---

<BaseLayout
  title={copy.cv.metaTitle}
  description={copy.cv.description}
  lang={lang}
  pageKey="cv"
>
  <div class="mt-16 mb-28 flex w-full max-w-4xl flex-col items-center gap-10 px-6 text-center lg:mt-20">
    <h1 class="page-title">{copy.cv.title}</h1>

    <p class="fade-in max-w-2xl text-base text-white/80 [animation-delay:0.2s] md:text-lg">
      {copy.cv.intro}
    </p>

    <div class="fade-in-up glass flex w-full max-w-xl flex-col items-center gap-6 rounded-2xl p-8 [animation-delay:0.3s]">
      <div class="inline-flex items-center gap-3 rounded-full border border-white/8 bg-white/4 px-4 py-2 text-white/70">
        <AstroIcon name="file" size="1.2em" />
        <span class="text-sm md:text-base">Ivan.pdf</span>
      </div>

      <a
        href={cvFile}
        download="Ivan.pdf"
        class="glass glass-cta inline-flex items-center gap-3 px-6 py-3 text-base font-semibold text-white/70 hover:text-white"
      >
        <AstroIcon name="download" size="1.2em" />
        {copy.cv.download}
      </a>

      <a
        href={cvFile}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-white/70 underline decoration-white/40 underline-offset-4 hover:text-white"
      >
        <AstroIcon name="external" size="1em" />
        {copy.cv.openPdf}
      </a>
    </div>
  </div>
</BaseLayout>
