---
import { Image } from "astro:assets";

import blobComfy from "../../public/blobcomfy.png";
import BaseLayout from "../layouts/BaseLayout.astro";
import AboutSection from "../components/AboutSection.astro";
import Icon from "../components/Icon.astro";
import TechGroup from "../components/TechGroup.astro";
import { defaultLang, getSiteCopy, normalizeLang, type SiteLang } from "../i18n";

interface Props {
  lang?: SiteLang;
}

const { lang: rawLang = defaultLang } = Astro.props;
const lang = normalizeLang(rawLang);
const copy = getSiteCopy(lang);
---

<BaseLayout
  title={copy.about.metaTitle}
  description={copy.about.description}
  lang={lang}
  pageKey="about"
>
  <div
    id="about-page"
    class="mt-8 mb-20 flex w-full max-w-5xl flex-col items-center gap-10 px-4 sm:mt-10 sm:px-6 sm:gap-14 lg:mt-20 lg:gap-18"
  >
    <div
      class="flex w-full max-w-3xl flex-col items-center gap-6 text-center md:flex-row md:items-start md:gap-10 md:text-left"
    >
      <div
        class="fade-in-up glass flex h-32 w-32 shrink-0 items-center justify-center rounded-full p-5 transition-[scale] duration-300 hover:scale-[1.05] md:h-36 md:w-36"
      >
        <Image
          src={blobComfy}
          alt="Blob Comfy"
          class="h-auto w-auto opacity-95 brightness-95 hue-rotate-30"
          loading="eager"
          decoding="async"
        />
      </div>
      <div class="flex flex-col gap-3">
        <h1 class="page-title drop-shadow-lg [animation-delay:0.1s]">
          {copy.about.title}
        </h1>
        <h2
          class="fade-in-up text-2xl font-bold text-white drop-shadow-lg [animation-delay:0.18s] md:text-3xl"
        >
          Ivan Ristić Hofrén
        </h2>
        <div
          class="fade-in flex flex-wrap justify-center gap-2 [animation-delay:0.25s] md:justify-start"
        >
          <div class="pill text-white/80">
            {copy.about.age}
          </div>
          <div class="pill text-white/80">{copy.about.school}</div>
        </div>
      </div>
    </div>

    <div
      class="fade-in-up content-block w-full max-w-3xl py-3 text-base drop-shadow-lg [animation-delay:0.3s] md:text-lg"
    >
      <p>{copy.about.intro}</p>
    </div>

    <div
      class="reveal flex w-full max-w-3xl items-center gap-3 font-sans text-sm text-white/60"
    >
      <Icon size="1.5em" img="lightbulb" />
      <p>
        {copy.about.builtWith} <span class="text-orange-200">HTML</span>,
        <span class="text-sky-200">Astro</span> och <span
        <span class="text-white/75">JavaScript</span
        >
      </p>
    </div>

    <hr class="reveal w-1/2 border-white/10" />

    <AboutSection title={copy.about.hobbiesTitle} icon="home" class="max-w-3xl">
      <div class="flex flex-col gap-8">
        <div class="reveal content-block py-2">
          <p>{copy.about.hobbiesText}</p>
        </div>

        <TechGroup heading={copy.about.interestsHeading}>
          <div class="flex flex-wrap gap-2">
            {copy.about.interests.map((interest, index) => (
              <span
                class:list={[
                  "pill",
                  [
                    "text-blue-200",
                    "text-emerald-300",
                    "text-violet-300",
                    "text-rose-200",
                    "text-purple-200",
                  ][index],
                ]}
              >
                {interest}
              </span>
            ))}
          </div>
        </TechGroup>
      </div>
    </AboutSection>

    <hr class="reveal w-1/2 border-white/10" />

    <AboutSection title={copy.about.workTitle} icon="lightbulb" class="max-w-3xl">
      <div class="flex flex-col gap-8">
        <div class="reveal content-block py-2">
          <p>{copy.about.workText}</p>
        </div>

        <TechGroup heading={copy.about.lessonsHeading}>
          <div class="flex flex-wrap gap-2">
            {copy.about.lessons.map((lesson, index) => (
              <span
                class:list={[
                  "pill",
                  [
                    "text-blue-200",
                    "text-emerald-300",
                    "text-violet-300",
                    "text-rose-200",
                    "text-purple-200",
                  ][index],
                ]}
              >
                {lesson}
              </span>
            ))}
          </div>
        </TechGroup>
      </div>
    </AboutSection>
  </div>
  <style>
    @reference '../styles/global.css';

    .section-cta {
      @apply flex flex-wrap gap-3 pt-5;
    }

    .gear-card {
      @apply rounded-xl p-5 transition-[scale] duration-300 hover:scale-[1.02];
    }
  </style>
</BaseLayout>
