---
import { Icon as AstroIcon } from "astro-icon/components";

interface Props {
  name: string;
  label: string;
  color?: string;
  description: string;
  categoryKey: string;
  categoryLabel: string;
  href?: string;
  linkLabel?: string;
  links?: Array<{ href: string; label: string }>;
  skill?: number;
}

const {
  name,
  label,
  color = "text-white/80",
  description,
  categoryKey,
  categoryLabel,
  href,
  linkLabel,
  links,
  skill,
} = Astro.props;

const fallbackLabel = href
  ? href.replace(/^https?:\/\/(www\.)?/i, "").replace(/\/$/, "")
  : "";

const linkItems = links?.length
  ? links
  : href
    ? [{ href, label: linkLabel ?? fallbackLabel }]
    : [];
---

<div
  class="reveal glass flex flex-col gap-4 rounded-xl p-5 transition-[scale,background-color,box-shadow] duration-300 hover:scale-[1.02] hover:bg-white/[0.06] hover:shadow-[0_0_20px_rgba(0,0,0,0.3)]"
  data-tags={categoryKey.toLowerCase()}
  data-name={name}
>
  <div class="flex items-center gap-3">
    <AstroIcon
      name={`stack/${name}`}
      size="2em"
      class:list={["shrink-0", color]}
    />
    <span class:list={["text-base font-bold", color]}>{label}</span>
  </div>
  <p class="flex-1 text-sm leading-relaxed text-white/60">{description}</p>
  <div>
    <span class="pill text-[0.65rem] text-white/50">{categoryLabel}</span>
  </div>
  {
    skill !== undefined && (
      <div class="skill-bar-wrap">
        <div class="skill-bar-track">
          <div class="skill-bar-fill" data-skill={skill} />
        </div>
        <span class="skill-label">{skill}%</span>
      </div>
    )
  }
  {
    linkItems.length > 0 && (
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
        {linkItems.map(({ href: itemHref, label: itemLabel }) => (
          <a
            href={itemHref}
            target="_blank"
            rel="noreferrer"
            class="text-xs font-semibold tracking-wide text-cyan-400/70 transition-colors hover:text-cyan-300"
          >
            {itemLabel}
          </a>
        ))}
      </div>
    )
  }
</div>

<style>
  .skill-bar-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .skill-bar-track {
    flex: 1;
    height: 2px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    overflow: hidden;
  }

  .skill-bar-fill {
    height: 100%;
    width: 0;
    border-radius: 999px;
    background: linear-gradient(
      to right,
      rgba(34, 211, 238, 0.25),
      rgba(103, 232, 249, 0.6)
    );
    box-shadow: 0 0 6px rgba(103, 232, 249, 0.15);
    transition: width 0.9s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .skill-label {
    font-size: 0.6rem;
    color: rgba(255, 255, 255, 0.3);
    min-width: 1.8rem;
    text-align: right;
  }
</style>
