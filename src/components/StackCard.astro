---
import { Icon as AstroIcon } from "astro-icon/components";

interface Props {
  name: string;
  label: string;
  color?: string;
  description: string;
  category: string;
  href?: string;
  linkLabel?: string;
  links?: Array<{ href: string; label: string }>;
}

const {
  name,
  label,
  color = "text-white/80",
  description,
  category,
  href,
  linkLabel,
  links,
} = Astro.props;

const fallbackLabel = href
  ? href.replace(/^https?:\/\/(www\.)?/i, "").replace(/\/$/, "")
  : "";

const linkItems = links?.length
  ? links
  : href
    ? [{ href, label: linkLabel ?? fallbackLabel }]
    : [];
---

<div
  class="reveal glass flex flex-col gap-4 rounded-xl p-5 transition-[scale,background-color] duration-300 hover:scale-[1.02] hover:bg-white/10"
  data-tags={category.toLowerCase()}
>
  <div class="flex items-center gap-3">
    <AstroIcon
      name={`stack/${name}`}
      size="2em"
      class:list={["shrink-0", color]}
    />
    <span class:list={["text-base font-bold", color]}>{label}</span>
  </div>
  <p class="flex-1 text-sm leading-relaxed text-white/60">{description}</p>
  <div>
    <span class="pill text-[0.65rem] text-white/50">{category}</span>
  </div>
  {
    linkItems.length > 0 && (
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
        {linkItems.map(({ href: itemHref, label: itemLabel }) => (
          <a
            href={itemHref}
            target="_blank"
            rel="noreferrer"
            class="text-xs font-semibold tracking-wide text-sky-200 transition-colors hover:text-sky-100"
          >
            {itemLabel}
          </a>
        ))}
      </div>
    )
  }
</div>
