---
import Icon from "./Icon.astro";

interface NavItem {
  name: string;
  url?: string;
}

interface Props {
  pages: NavItem[];
}

const { pages } = Astro.props;
const currentPath = Astro.url.pathname;
const basePath = import.meta.env.BASE_URL;
---

<nav
  id="main-nav"
  transition:persist
  class="nav-glass font-soft flex flex-wrap items-center gap-4 p-3 transition-[background-color,backdrop-filter,border-color,box-shadow] duration-500 md:gap-6 md:px-6 md:py-4"
>
  <Icon
    size="2em"
    img="home"
    href={basePath}
    target="_self"
    class="h-6 w-6 md:h-7 md:w-7"
    color="text-white"
    label="Hem"
  />
  <div class="flex flex-wrap items-center gap-4 md:gap-7">
    {
      pages.map((page) => {
        const href = `${basePath}${(page.url || `/${page.name.toLowerCase()}`).replace(/^\//, "")}`;
        const isActive =
          currentPath === href || currentPath.startsWith(href + "/");

        return (
          <a
            class="nav-link text-sm tracking-wide md:text-base"
            href={href}
            data-text={page.name}
            aria-current={isActive ? "page" : undefined}
          >
            {page.name}
          </a>
        );
      })
    }
  </div>
</nav>

<style>
  @reference '../styles/global.css';

  .nav-link {
    @apply inline-flex flex-col items-center justify-center border-b-2 border-white/30 font-normal text-white/80;
  }

  @media (hover: hover) {
    .nav-link {
      transition: color 200ms ease, border-color 200ms ease;
    }

    .nav-link:hover {
      @apply border-white/80 text-white;
    }
  }

  .nav-link.navigating {
    transition:
      font-weight 700ms ease,
      color 700ms ease,
      border-color 700ms ease;
  }

  .nav-link[aria-current="page"] {
    @apply border-white font-bold text-white;
  }

  .nav-link::after {
    content: attr(data-text);
    @apply pointer-events-none invisible h-0 overflow-hidden font-bold;
  }

  .nav-glass {
    @apply border-b-[0.5px] border-white/5 bg-transparent;
  }

  .nav-glass.scrolled {
    @apply border-b-[0.5px] border-white/15 bg-white/6;
    backdrop-filter: saturate(110%);
    box-shadow:
      inset 0 0.5px 0 0 rgba(255, 255, 255, 0.2),
      0 1px 8px rgba(0, 0, 0, 0.04);
  }
</style>

<script>
  let prevScrollHandler: (() => void) | null = null;

  document.addEventListener("astro:page-load", () => {
    const nav = document.getElementById("main-nav");
    if (!nav) {
      return;
    }

    const currentPath = window.location.pathname;
    const links = nav.querySelectorAll<HTMLAnchorElement>(".nav-link");
    links.forEach((link) => link.classList.add("navigating"));

    requestAnimationFrame(() => {
      links.forEach((link) => {
        const href = link.getAttribute("href");
        if (
          href &&
          (currentPath === href || currentPath.startsWith(href + "/"))
        ) {
          link.setAttribute("aria-current", "page");
        } else {
          link.removeAttribute("aria-current");
        }
      });

      setTimeout(() => {
        links.forEach((link) => link.classList.remove("navigating"));
      }, 700);
    });

    if (prevScrollHandler) {
      window.removeEventListener("scroll", prevScrollHandler);
      document.body.removeEventListener("scroll", prevScrollHandler);
    }

    const isCoarse = window.matchMedia("(pointer: coarse)").matches;
    const scrollEl = isCoarse ? document.body : window;

    const onScroll = () => {
      const y = isCoarse ? document.body.scrollTop : window.scrollY;
      nav.classList.toggle("scrolled", y > 20);
    };
    prevScrollHandler = onScroll;

    onScroll();
    scrollEl.addEventListener("scroll", onScroll, { passive: true });
  });
</script>
