---
import Icon from "./Icon.astro";
import { defaultLang, getSiteCopy, normalizeLang, type SiteLang } from "../i18n";

interface Props {
  text?: string;
  lang?: SiteLang;
}

const {
  text,
  lang: rawLang = defaultLang,
} = Astro.props;
const lang = normalizeLang(rawLang);
const copy = getSiteCopy(lang);
const footerText = text ?? copy.footer.text;

const socials = [
  { img: "mail", href: "mailto:ivanristichofren@outlook.com", label: copy.footer.socials.email },
  { img: "github", href: "https://github.com/ivanriho", label: copy.footer.socials.github },
  {
    img: "discord",
    href: "https://discord.com/users/1479856948823461909",
    label: copy.footer.socials.discord,
  },
];
---

<footer class="reveal relative flex-none p-8 text-center text-xl">
  <div class="flex flex-wrap justify-center gap-2 p-5 md:gap-3">
    {
      socials.map((social) => (
        <Icon
          class="h-11 w-11 md:h-15 md:w-15"
          img={social.img}
          href={social.href}
          label={social.label}
        />
      ))
    }
  </div>
  <p class="text-lg md:text-xl">{footerText}</p>
</footer>
