---
import { Icon as AstroIcon } from "astro-icon/components";

interface Props {
  name: string;
  label?: string;
  color?: string;
  class?: string;
}

const { name, label, color = "", class: className = "" } = Astro.props;
---

<div
  class:list={[
    "glass tech-card flex items-center gap-3 rounded-2xl px-4 py-3 transition-[scale,background-color,border-color] duration-300 hover:scale-[1.03] hover:bg-white/10",
    className,
  ]}
>
  <AstroIcon
    name={`stack/${name}`}
    size="1.7em"
    class:list={["shrink-0", color]}
  />
  {label && <span class:list={["text-base font-semibold", color]}>{label}</span>}
</div>