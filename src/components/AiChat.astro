---
// AiChat.astro – floating AI chat widget
const OPENAI_API_KEY = import.meta.env.OPENAI_API_KEY ?? "";
---

<!-- ── Toggle button (always visible) ──────────────────────────── -->
<button
  id="ai-chat-toggle"
  aria-label="Öppna AI-chat"
  aria-expanded="false"
  aria-controls="ai-chat-panel"
  class="ai-toggle"
>
  <!-- Spark icon (open state) -->
  <svg
    id="ai-toggle-icon-open"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path
      d="M12 2a1 1 0 0 1 .95.68l1.6 4.84 4.84 1.6a1 1 0 0 1 0 1.9l-4.84 1.6-1.6 4.84a1 1 0 0 1-1.9 0l-1.6-4.84-4.84-1.6a1 1 0 0 1 0-1.9l4.84-1.6 1.6-4.84A1 1 0 0 1 12 2Z"
    ></path>
    <path d="M5 17l-.94 2.83L1.23 21l2.83.94.94 2.83.94-2.83L8.77 21l-2.83-.94Z"
    ></path>
    <path d="M19 3l-.63 1.88-1.88.63 1.88.63.63 1.88.63-1.88 1.88-.63-1.88-.63Z"
    ></path>
  </svg>
  <!-- X icon (close state, hidden initially) -->
  <svg
    id="ai-toggle-icon-close"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    style="display:none"
    aria-hidden="true"
  >
    <line x1="18" y1="6" x2="6" y2="18"></line>
    <line x1="6" y1="6" x2="18" y2="18"></line>
  </svg>
</button>

<!-- ── Chat panel ───────────────────────────────────────────────── -->
<aside
  id="ai-chat-panel"
  role="dialog"
  aria-label="AI-chat"
  aria-modal="false"
  class="ai-panel"
  data-open="false"
>
  <!-- Header -->
  <header class="ai-panel-header">
    <span class="ai-panel-title">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="ai-header-icon"
        aria-hidden="true"
      >
        <path
          d="M12 2a1 1 0 0 1 .95.68l1.6 4.84 4.84 1.6a1 1 0 0 1 0 1.9l-4.84 1.6-1.6 4.84a1 1 0 0 1-1.9 0l-1.6-4.84-4.84-1.6a1 1 0 0 1 0-1.9l4.84-1.6 1.6-4.84A1 1 0 0 1 12 2Z"
        ></path>
      </svg>
      AI-assistent
    </span>
    <button
      id="ai-chat-minimize"
      class="ai-minimize-btn"
      aria-label="Minimera chat"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="5" y1="12" x2="19" y2="12"></line>
      </svg>
    </button>
  </header>

  <!-- Messages -->
  <div id="ai-chat-messages" class="ai-messages" aria-live="polite" aria-atomic="false">
    <div class="ai-msg ai-msg--assistant">
      <span class="ai-msg-label">AI</span>
      <p class="ai-msg-text">
        Hej! Jag är Ivans AI-assistent. Fråga mig vad du vill om Ivan, hans
        projekt eller kompetenser.
      </p>
    </div>
  </div>

  <!-- Input -->
  <form id="ai-chat-form" class="ai-input-row" autocomplete="off">
    <input
      id="ai-chat-input"
      class="ai-input"
      type="text"
      placeholder="Skriv ett meddelande…"
      maxlength="500"
      autocomplete="off"
      spellcheck="false"
      required
    />
    <button type="submit" class="ai-send-btn" aria-label="Skicka">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="ai-send-icon"
        aria-hidden="true"
      >
        <line x1="22" y1="2" x2="11" y2="13"></line>
        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
      </svg>
    </button>
  </form>
</aside>

<style>
  @reference '../styles/global.css';

  /* ── Toggle button ───────────────────────────────────────── */
  .ai-toggle {
    @apply fixed bottom-6 right-6 z-50 flex h-13 w-13 cursor-pointer items-center justify-center rounded-full border border-white/35 bg-white/10 text-white shadow-lg backdrop-blur-md transition-all duration-300;
    box-shadow:
      inset 0 4px 20px rgba(255, 255, 255, 0.1),
      0 4px 24px rgba(0, 0, 0, 0.25);
  }

  .ai-toggle svg {
    @apply h-6 w-6;
  }

  @media (hover: hover) {
    .ai-toggle:hover {
      @apply scale-110 bg-white/20;
    }
  }

  /* ── Chat panel ──────────────────────────────────────────── */
  .ai-panel {
    @apply fixed bottom-24 right-6 z-50 flex w-80 flex-col overflow-hidden rounded-2xl border border-white/35 bg-white/[0.07] text-white shadow-2xl backdrop-blur-md;
    box-shadow:
      inset 0 4px 20px rgba(255, 255, 255, 0.08),
      0 8px 40px rgba(0, 0, 0, 0.35);
    /* panel height cap */
    max-height: min(520px, calc(100svh - 7rem));
    /* hidden state */
    opacity: 0;
    pointer-events: none;
    transform: translateY(12px) scale(0.97);
    transform-origin: bottom right;
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
  }

  .ai-panel[data-open="true"] {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  /* glass shimmer layer – mirrors .glass::after */
  .ai-panel::after {
    @apply absolute top-0 left-0 -z-1 h-full w-full rounded-[inherit] bg-white/4 opacity-40 backdrop-blur-[1px] content-[''];
    box-shadow:
      inset -10px -8px 0px -11px rgba(255, 255, 255, 0.5),
      inset 0px -9px 0px -8px rgba(255, 255, 255, 0.5);
    filter: blur(1px) drop-shadow(10px 4px 6px rgba(0, 0, 0, 0.3)) brightness(110%);
    pointer-events: none;
  }

  /* ── Header ──────────────────────────────────────────────── */
  .ai-panel-header {
    @apply flex flex-none items-center justify-between border-b border-white/15 px-4 py-3;
  }

  .ai-panel-title {
    @apply flex items-center gap-2 text-sm font-semibold tracking-wide text-white;
  }

  .ai-header-icon {
    @apply h-4 w-4 opacity-80;
  }

  .ai-minimize-btn {
    @apply flex h-7 w-7 cursor-pointer items-center justify-center rounded-full border border-white/20 bg-white/5 text-white/70 transition-colors duration-200;
  }

  @media (hover: hover) {
    .ai-minimize-btn:hover {
      @apply bg-white/15 text-white;
    }
  }

  .ai-minimize-btn svg {
    @apply h-3.5 w-3.5;
  }

  /* ── Messages ────────────────────────────────────────────── */
  .ai-messages {
    @apply flex flex-1 flex-col gap-3 overflow-y-auto px-4 py-4;
    scroll-behavior: smooth;
    /* custom thin scrollbar */
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.2) transparent;
  }

  .ai-msg {
    @apply flex flex-col gap-1;
  }

  .ai-msg--user {
    @apply items-end;
  }

  .ai-msg--assistant {
    @apply items-start;
  }

  .ai-msg-label {
    @apply px-1 text-[10px] font-semibold tracking-widest text-white/40 uppercase;
  }

  .ai-msg-text {
    @apply max-w-[90%] rounded-xl px-3.5 py-2.5 text-sm leading-relaxed;
  }

  .ai-msg--user .ai-msg-text {
    @apply rounded-tr-sm border border-white/20 bg-white/15;
  }

  .ai-msg--assistant .ai-msg-text {
    @apply rounded-tl-sm border border-white/12 bg-white/6;
  }

  /* typing indicator dots */
  .ai-typing .ai-msg-text {
    @apply flex items-center gap-1 px-4 py-3;
  }

  .ai-typing .dot {
    @apply h-1.5 w-1.5 rounded-full bg-white/60;
    animation: dot-pulse 1.2s ease-in-out infinite;
  }

  .ai-typing .dot:nth-child(2) {
    animation-delay: 0.2s;
  }

  .ai-typing .dot:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes dot-pulse {
    0%, 80%, 100% {
      opacity: 0.3;
      transform: scale(0.85);
    }
    40% {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* ── Input row ───────────────────────────────────────────── */
  .ai-input-row {
    @apply flex flex-none items-center gap-2 border-t border-white/15 px-3 py-3;
  }

  .ai-input {
    @apply min-w-0 flex-1 rounded-xl border border-white/20 bg-white/8 px-3.5 py-2 text-sm text-white placeholder-white/35 outline-none transition-colors duration-200;
  }

  .ai-input:focus {
    @apply border-white/45 bg-white/12;
  }

  .ai-send-btn {
    @apply flex h-9 w-9 flex-none cursor-pointer items-center justify-center rounded-xl border border-white/20 bg-white/10 text-white/80 transition-all duration-200;
  }

  @media (hover: hover) {
    .ai-send-btn:hover:not(:disabled) {
      @apply scale-105 bg-white/20 text-white;
    }
  }

  .ai-send-btn:disabled {
    @apply cursor-not-allowed opacity-40;
  }

  .ai-send-icon {
    @apply h-4 w-4;
  }

  /* ── Mobile: full-width on very small screens ────────────── */
  @media (max-width: 359px) {
    .ai-panel {
      @apply right-3 w-[calc(100vw-1.5rem)];
    }
    .ai-toggle {
      @apply right-3;
    }
  }
</style>

<script is:inline define:vars={{ OPENAI_API_KEY }}>
  const KEY = OPENAI_API_KEY;

  const SYSTEM_PROMPT = `Du är en vänlig och korrekt AI-assistent för Ivan Ristić Hofréns portfolio.

Språk och stil:
- Svara alltid på samma språk som användaren skriver.
- Håll svar korta, tydliga och sakliga.
- Hitta inte på fakta. Om något saknas på hemsidan, säg det tydligt.

Begränsning:
- Du får endast svara på saker som hej, hur mår du och sådant och frågor som handlar om Ivan Ristić Hofrén, hans bakgrund, hans erfarenhet, hans hemsida, hans CV och hans tekniska stack.
- Om frågan inte handlar om Ivan eller hans hemsida ska du inte besvara frågan.
- Vid frågor utanför detta område ska du alltid svara exakt:
  "Jag svarar bara på frågor om Ivan. Om du vill prata om annat, använd ChatGPT."
- Du får prata andra språk

Detta vet du om Ivan (enligt hemsidan):
- Namn: Ivan Ristić Hofrén.
- Ålder: 15 år (född 2010).
- Bor i: Malmö, Sverige.
- Roll: Elev och fritidsutvecklare.
- Skola: Fågelbacksskolan.

Personligt:
- Ivan beskriver sig som social, ansvarstagande och självständig.
- Han är tekniskt intresserad och bygger webbsidor på fritiden.
- Han tävlingssimmar i Vellinge.
- Han gillar djur och har en hund.
- Han gillar att resa och att umgås med vänner.

Erfarenhet:
- PRAO i två veckor på ICA.
- Arbetsuppgifter: varuplock, frontning av hyllor, hjälp i kassa, sortering/uppackning i lager, kundservice och ordning i butik.

Hemsidan:
- Har sidorna: Om mig, CV och Stack.
- CV finns som PDF och kan laddas ner eller öppnas i ny flik.

Teknisk profil och stack:
- Frontend och web: HTML5, Tailwind CSS, TypeScript, Next.js, Astro, JavaScript.
- Backend/data: Prisma + PostgreSQL, Auth.js.
- DevOps/verktyg: Git och GitHub.
- Ivan arbetar med moderna webbprojekt och fullstacklösningar.

När du svarar om kompetens:
- Beskriv styrkor och relevanta tekniker på ett konkret sätt.
- Om någon frågar om kontakt, föreslå att se sociala ikoner/footer på hemsidan (e-post, GitHub, Discord).

Mål:
- Hjälp besökare att snabbt förstå vem Ivan är, vad han kan och hur de kan gå vidare (t.ex. läsa stacken eller ladda ner CV).`;

  /** @type {{ role: 'user' | 'assistant'; content: string }[]} */
  const history = [];

  const toggleBtn = /** @type {HTMLButtonElement} */ (document.getElementById("ai-chat-toggle"));
  const panel = /** @type {HTMLElement} */ (document.getElementById("ai-chat-panel"));
  const minimizeBtn = document.getElementById("ai-chat-minimize");
  const messagesEl = /** @type {HTMLElement} */ (document.getElementById("ai-chat-messages"));
  const form = /** @type {HTMLFormElement} */ (document.getElementById("ai-chat-form"));
  const input = /** @type {HTMLInputElement} */ (document.getElementById("ai-chat-input"));
  const sendBtn = form.querySelector("button[type='submit']");
  const iconOpen = document.getElementById("ai-toggle-icon-open");
  const iconClose = document.getElementById("ai-toggle-icon-close");

  let isOpen = false;

  function openPanel() {
    isOpen = true;
    panel.dataset.open = "true";
    toggleBtn.setAttribute("aria-expanded", "true");
    iconOpen.style.display = "none";
    iconClose.style.display = "";
    input.focus();
  }

  function closePanel() {
    isOpen = false;
    panel.dataset.open = "false";
    toggleBtn.setAttribute("aria-expanded", "false");
    iconOpen.style.display = "";
    iconClose.style.display = "none";
  }

  toggleBtn.addEventListener("click", () => {
    if (isOpen) closePanel();
    else openPanel();
  });

  minimizeBtn?.addEventListener("click", closePanel);

  /** Scroll the message list to the bottom */
  function scrollToBottom() {
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  /**
   * Append a message bubble and return its <p> element.
   * @param {'user'|'assistant'} role
   * @param {string} [text]
   * @param {boolean} [typing]
   * @returns {HTMLParagraphElement}
   */
  function appendMessage(role, text = "", typing = false) {
    const wrapper = document.createElement("div");
    wrapper.className = `ai-msg ai-msg--${role}${typing ? " ai-typing" : ""}`;

    const label = document.createElement("span");
    label.className = "ai-msg-label";
    label.textContent = role === "user" ? "Du" : "AI";

    const bubble = document.createElement("p");
    bubble.className = "ai-msg-text";

    if (typing) {
      for (let i = 0; i < 3; i++) {
        const dot = document.createElement("span");
        dot.className = "dot";
        bubble.appendChild(dot);
      }
    } else {
      bubble.textContent = text;
    }

    wrapper.appendChild(label);
    wrapper.appendChild(bubble);
    messagesEl.appendChild(wrapper);
    scrollToBottom();
    return bubble;
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const userText = input.value.trim();
    if (!userText) return;

    // Show user message
    input.value = "";
    sendBtn.disabled = true;
    appendMessage("user", userText);
    history.push({ role: "user", content: userText });

    // Show typing indicator
    const typingEl = document.createElement("div");
    typingEl.className = "ai-msg ai-msg--assistant ai-typing";
    const typingLbl = document.createElement("span");
    typingLbl.className = "ai-msg-label";
    typingLbl.textContent = "AI";
    const typingBubble = document.createElement("p");
    typingBubble.className = "ai-msg-text";
    for (let i = 0; i < 3; i++) {
      const d = document.createElement("span");
      d.className = "dot";
      typingBubble.appendChild(d);
    }
    typingEl.appendChild(typingLbl);
    typingEl.appendChild(typingBubble);
    messagesEl.appendChild(typingEl);
    scrollToBottom();

    try {
      const response = await fetch("https://api.openai.com/v1/chat/completions", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${KEY}`,
        },
        body: JSON.stringify({
          model: "gpt-4o-mini",
          max_tokens: 400,
          messages: [
            { role: "system", content: SYSTEM_PROMPT },
            ...history,
          ],
        }),
      });

      if (!response.ok) {
        throw new Error(`API-fel ${response.status}`);
      }

      const data = await response.json();
      const assistantText =
        data.choices?.[0]?.message?.content?.trim() ??
        "Tyvärr fick jag inget svar.";

      // Remove typing indicator and show real reply
      messagesEl.removeChild(typingEl);
      appendMessage("assistant", assistantText);
      history.push({ role: "assistant", content: assistantText });
    // Cap history to last 20 messages to avoid token limits
    if (history.length > 20) history.splice(0, history.length - 20);
    } catch (err) {
      messagesEl.removeChild(typingEl);
      appendMessage(
        "assistant",
        "Något gick fel. Kontrollera din anslutning och försök igen."
      );
      console.error(err);
    } finally {
      sendBtn.disabled = false;
      input.focus();
    }
  });

  // Also allow Enter to submit (no newlines needed)
  input.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      form.requestSubmit();
    }
  });
</script>
