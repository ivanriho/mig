---
import Icon from "./Icon.astro";

interface Props {
  title: string;
  icon: string;
  class?: string;
}

const { title, icon, class: className } = Astro.props;
---

<section class:list={["flex w-full flex-col gap-6", className]}>
  <div class="reveal flex flex-col gap-3">
    <h2
      class="flex flex-wrap items-center gap-3 text-3xl font-extrabold text-cyan-300 mystic-glow drop-shadow-lg md:text-4xl"
    >
      {title}
      <Icon size="1em" img={icon} class="pointer-events-none" />
    </h2>
    <hr class="w-1/3 border-white/10" />
  </div>
  <div class="text-lg drop-shadow-md"><slot /></div>
</section>

<style>
  .mystic-glow {
    text-shadow: 0 0 28px rgba(103, 232, 249, 0.2);
  }

  :global([data-theme="original"]) .mystic-glow {
    text-shadow: none;
  }
</style>
